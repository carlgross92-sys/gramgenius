# ── Database (Neon PostgreSQL)
DATABASE_URL=

# ── Anthropic (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=

# ── OpenAI (platform.openai.com → API Keys) — used for DALL-E 3 image generation
OPENAI_API_KEY=

# ── Runway ML (dev.runwayml.com → Key Management) — used for AI video generation
RUNWAYML_API_KEY=

# ── ElevenLabs (elevenlabs.io → Profile → API Key) — used for AI voiceovers
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Meta / Instagram Graph API (see docs/meta-setup.md)
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_PAGE_ID=

# ── Vercel Blob Storage (vercel.com → Project → Storage → Blob)
BLOB_READ_WRITE_TOKEN=

# ── Vercel Cron Secret
CRON_SECRET=

# ── App
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
NODE_ENV=development
